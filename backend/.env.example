# ─── Configuração do Sector-RAG ────────────────────────────────────────
# Copie este arquivo para .env e ajuste se necessário.
# Se o .env não existir, o sistema usa os valores padrão.

# ── Ollama (local) ─────────────────────────────────────────────────────
RAG_OLLAMA_BASE_URL=http://localhost:11434
RAG_LLM_MODEL=qwen2.5:0.5b
RAG_EMBEDDING_MODEL=nomic-embed-text

# ── ChromaDB ──────────────────────────────────────────────────────────
RAG_CHROMA_PERSIST_DIR=./data/chroma
RAG_COLLECTION_NAME=rag_docs

# ── App ────────────────────────────────────────────────────────────────
RAG_DEBUG=true
RAG_APP_NAME=Sector-RAG

# ── Reranking ─────────────────────────────────────────────────────────
RAG_RERANKING_ENABLED=false
